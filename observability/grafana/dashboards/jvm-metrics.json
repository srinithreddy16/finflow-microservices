{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "description": "JVM metrics per FinFlow service — heap, GC, threads",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "JVM Heap Used (MB) — All Services",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by (job) (jvm_memory_used_bytes{area='heap'}) / 1024 / 1024",
          "legendFormat": "{{job}}",
          "range": true
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": { "defaults": { "unit": "megabytes" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "GC Pause Time (ms) — All Services",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by (job) (rate(jvm_gc_pause_seconds_sum[1m])) / sum by (job) (rate(jvm_gc_pause_seconds_count[1m])) * 1000",
          "legendFormat": "Avg GC pause {{job}}",
          "range": true
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Active Threads — All Services",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by (job) (jvm_threads_live_threads)",
          "legendFormat": "{{job}}",
          "range": true
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU Usage — All Services",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "system_cpu_usage{job=~'.+'}",
          "legendFormat": "{{job}}",
          "range": true
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["finflow", "jvm"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FinFlow — JVM Metrics",
  "uid": "finflow-jvm",
  "version": 1
}
