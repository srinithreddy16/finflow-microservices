{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "description": "FinFlow Saga Orchestration Monitor — success/failure/compensation rates",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Sagas Completed Today",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum(increase(saga_completed_total{job='saga-orchestrator-service'}[24h])) or vector(0)",
          "range": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Sagas Failed Today",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum(increase(saga_failed_total{job='saga-orchestrator-service'}[24h])) or vector(0)",
          "range": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Compensations Triggered Today",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum(increase(saga_compensation_total{job='saga-orchestrator-service'}[24h])) or vector(0)",
          "range": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Sagas Now",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "saga_active_count{job='saga-orchestrator-service'} or vector(0)",
          "range": true
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Saga Throughput (started/completed/failed per min)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "editorMode": "code", "expr": "sum(rate(saga_started_total{job='saga-orchestrator-service'}[1m])) * 60", "legendFormat": "Started/min", "range": true },
        { "refId": "B", "editorMode": "code", "expr": "sum(rate(saga_completed_total{job='saga-orchestrator-service'}[1m])) * 60", "legendFormat": "Completed/min", "range": true },
        { "refId": "C", "editorMode": "code", "expr": "sum(rate(saga_failed_total{job='saga-orchestrator-service'}[1m])) * 60", "legendFormat": "Failed/min", "range": true }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": { "defaults": { "unit": "cpm" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "RabbitMQ Saga Queue Message Rates",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "editorMode": "code", "expr": "rabbitmq_queue_messages{queue='saga.replies.queue'}", "legendFormat": "saga.replies depth", "range": true },
        { "refId": "B", "editorMode": "code", "expr": "rabbitmq_queue_messages{queue='saga.dead-letter'}", "legendFormat": "DLQ depth (alarming)", "range": true }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["finflow", "saga"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FinFlow — Saga Monitor",
  "uid": "finflow-saga",
  "version": 1
}
