###

### [12] Get Non-existent Account (should fail 404)
GET {{accountServiceUrl}}/api/accounts/non-existent-id-00000
Authorization: Bearer {{token}}

> {%
  client.test("Non-existent account returns 404", function() {
    client.assert(response.status === 404,
      "Expected 404 Not Found");
  });
  client.test("Error has errorCode ACCOUNT_NOT_FOUND", function() {
    client.assert(response.body.errorCode === "ACCOUNT_NOT_FOUND",
      "Expected ACCOUNT_NOT_FOUND errorCode");
  });
%}

###

### [13] Suspend Account
PATCH {{accountServiceUrl}}/api/accounts/{{accountId}}/status
Authorization: Bearer {{token}}
Content-Type: application/json
X-Correlation-Id: corr-suspend-001

{
  "status": "SUSPENDED",
  "reason": "Policy violation during testing"
}

> {%
  client.test("Account suspended — 200", function() {
    client.assert(response.status === 200, "Expected 200 OK");
  });
  client.test("Status is SUSPENDED", function() {
    client.assert(response.body.status === "SUSPENDED",
      "Expected SUSPENDED status");
  });
%}

###

### [14] Reactivate Account
PATCH {{accountServiceUrl}}/api/accounts/{{accountId}}/status
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "ACTIVE",
  "reason": "Resolved — reactivating for testing"
}

> {%
  client.test("Account reactivated — 200", function() {
    client.assert(response.status === 200, "Expected 200 OK");
  });
  client.test("Status is ACTIVE", function() {
    client.assert(response.body.status === "ACTIVE",
      "Expected ACTIVE status");
  });
%}
