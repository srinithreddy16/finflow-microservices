### ──────────────────────────────────────────────────────────────
### FinFlow — Complete End-to-End Flow
### Runs the full $500 payment flow across all services
###
### ORDER TO RUN:
### 1.  Get token
### 2.  Create tenant
### 3.  Create account
### 4.  Create transaction ($500)
### 5.  Verify fraud check passed
### 6.  Verify payment created (choreography saga)
### 7.  Verify ledger entries (double-entry bookkeeping)
### 8.  Verify account balance updated
### 9.  Check analytics (wait 15s for Kafka)
### 10. Generate report
### 11. Start onboarding saga
### 12. Poll saga to COMPLETED
### 13. GraphQL dashboard query
### ──────────────────────────────────────────────────────────────

### STEP 1 — Get Access Token
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type=password&client_id={{clientId}}&client_secret={{clientSecret}}&username={{adminUsername}}&password={{adminPassword}}

> {%
  client.global.set("token", response.body.access_token);
  client.log("STEP 1 ✅ Token obtained");
%}

###

### STEP 2 — Create Tenant
POST {{accountServiceUrl}}/api/tenants
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "E2E Test Corp",
  "slug": "e2e-test-corp",
  "ownerEmail": "e2e@test.com"
}

> {%
  client.global.set("tenantId", response.body.id);
  client.log("STEP 2 ✅ Tenant: " + response.body.id);
%}

###

### STEP 3 — Create Account
POST {{accountServiceUrl}}/api/accounts
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "email": "e2e.user@test.com",
  "firstName": "E2E",
  "lastName": "User",
  "phoneNumber": "+9999999999",
  "tenantId": "{{tenantId}}"
}

> {%
  client.test("Account created", function() {
    client.assert(response.status === 201, "Expected 201");
  });
  client.global.set("accountId", response.body.id);
  client.log("STEP 3 ✅ Account: " + response.body.id);
%}

###

### STEP 4 — Create Transaction ($500 — normal amount)
POST {{transactionServiceUrl}}/api/transactions
Authorization: Bearer {{token}}
Content-Type: application/json
X-User-Id: e2e-user

{
  "accountId": "{{accountId}}",
  "amount": 500.00,
  "currency": "USD",
  "description": "E2E payment test"
}

> {%
  client.test("Transaction created", function() {
    client.assert(response.status === 201, "Expected 201");
  });
  client.test("Status is PENDING", function() {
    client.assert(response.body.status === "PENDING",
      "Expected PENDING");
  });
  client.global.set("transactionId", response.body.id);
  client.log("STEP 4 ✅ Transaction: " + response.body.id);
  client.log("  → Fraud check passed (amount < $10,000)");
  client.log("  → PaymentInitiated published to RabbitMQ");
  client.log("  → Payment service will process asynchronously");
%}

###

### STEP 5 — Verify Payment Created (wait 2 seconds first)
GET {{paymentServiceUrl}}/api/payments/transaction/{{transactionId}}
Authorization: Bearer {{token}}

> {%
  client.test("Payment created via choreography saga", function() {
    client.assert(response.status === 200,
      "Expected 200 — choreography saga should have created payment");
  });
  client.global.set("paymentId", response.body.id);
  client.log("STEP 5 ✅ Payment: " + response.body.id);
  client.log("  → Payment status: " + response.body.status);
  client.log("  → Choreography saga working correctly");
%}

###

### STEP 6 — Verify Double-Entry Ledger
GET {{paymentServiceUrl}}/api/payments/{{paymentId}}/ledger
Authorization: Bearer {{token}}

> {%
  client.test("Double-entry ledger created", function() {
    client.assert(response.status === 200, "Expected 200");
    client.assert(response.body.length === 2,
      "Expected 2 ledger entries (DEBIT + CREDIT)");
  });
  const debit = response.body.find(e => e.entryType === "DEBIT");
  const credit = response.body.find(e => e.entryType === "CREDIT");
  client.test("DEBIT entry exists for $500", function() {
    client.assert(debit !== undefined, "Expected DEBIT entry");
  });
  client.test("CREDIT entry exists for $500", function() {
    client.assert(credit !== undefined, "Expected CREDIT entry");
  });
  client.log("STEP 6 ✅ Double-entry bookkeeping verified");
  client.log("  DEBIT: -$" + (debit ? debit.amount : "N/A"));
  client.log("  CREDIT: +$" + (credit ? credit.amount : "N/A"));
%}

###

### STEP 7 — Check Account Balance
GET {{paymentServiceUrl}}/api/payments/account/{{accountId}}/balance
Authorization: Bearer {{token}}

> {%
  client.test("Balance returned", function() {
    client.assert(response.status === 200, "Expected 200");
  });
  client.log("STEP 7 ✅ Account balance: " +
             response.body.balance + " " + response.body.currency);
%}

###

### STEP 8 — Check Analytics (wait 15s for Kafka processing)
# Note: If totalTransactions is 0, wait longer and retry
GET {{analyticsServiceUrl}}/api/analytics/summary/{{accountId}}
Authorization: Bearer {{token}}

> {%
  client.test("Analytics populated via Kafka", function() {
    client.assert(response.status === 200, "Expected 200");
  });
  client.log("STEP 8 ✅ Analytics via Kafka");
  client.log("  Total transactions: " + response.body.totalTransactions);
  client.log("  Total volume: $" + response.body.totalVolume);
  client.log("  (If 0, wait 15s and retry — Kafka is async)");
%}

###

### STEP 9 — Generate Report
POST {{reportServiceUrl}}/api/reports
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "accountId": "{{accountId}}",
  "reportType": "TRANSACTION_HISTORY",
  "format": "PDF"
}

> {%
  client.test("Report generated", function() {
    client.assert(response.status === 202, "Expected 202");
    client.assert(response.body.status === "READY",
      "Expected READY status");
  });
  client.global.set("reportId", response.body.id);
  client.log("STEP 9 ✅ Report generated: " + response.body.id);
  client.log("  Download URL: " + response.body.downloadUrl);
%}

###

### STEP 10 — Start Onboarding Saga
POST {{sagaOrchestratorUrl}}/api/saga/onboarding
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "email": "saga.e2e@test.com",
  "firstName": "Saga",
  "lastName": "TestUser",
  "phoneNumber": "+8888888888",
  "tenantId": "{{tenantId}}"
}

> {%
  client.test("Saga started", function() {
    client.assert(response.status === 202, "Expected 202");
  });
  client.global.set("sagaId", response.body.sagaId);
  client.log("STEP 10 ✅ Saga started: " + response.body.sagaId);
  client.log("  State: " + response.body.state);
  client.log("  → Poll GET /api/saga/{sagaId} to track progress");
%}

###

### STEP 11 — Poll Saga Status (run multiple times)
GET {{sagaOrchestratorUrl}}/api/saga/{{sagaId}}
Authorization: Bearer {{token}}

> {%
  client.log("Saga state: " + response.body.state);
  client.log("Step: " + response.body.currentStep);
  if (response.body.state === "COMPLETED") {
    client.log("STEP 11 ✅ SAGA COMPLETED! Full onboarding done.");
    client.log("  Account ID: " + response.body.accountId);
  }
%}

###

### STEP 12 — GraphQL Dashboard Query
POST {{graphqlGatewayUrl}}/graphql
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "query": "query FullDashboard($accountId: ID!) { analyticsSummary(accountId: $accountId) { totalTransactions completedTransactions totalVolume fraudRate } account(id: $accountId) { email firstName lastName status kycVerified } reportsByAccount(accountId: $accountId) { totalElements content { id name status reportType } } }",
  "variables": {
    "accountId": "{{accountId}}"
  }
}

> {%
  client.test("GraphQL dashboard query — 200", function() {
    client.assert(response.status === 200, "Expected 200");
  });
  client.test("No GraphQL errors", function() {
    client.assert(response.body.errors === undefined,
      "No errors: " + JSON.stringify(response.body.errors));
  });
  client.log("STEP 12 ✅ GraphQL combined dashboard query");
  client.log("  Account: " + response.body.data.account?.email);
  client.log("  Total transactions: " +
    response.body.data.analyticsSummary?.totalTransactions);
  client.log("  Total reports: " +
    response.body.data.reportsByAccount?.totalElements);
  client.log("");
  client.log("🎉 COMPLETE END-TO-END FLOW VERIFIED!");
  client.log("  ✅ Account created");
  client.log("  ✅ Transaction processed (fraud check + payment saga)");
  client.log("  ✅ Double-entry ledger entries created");
  client.log("  ✅ Analytics populated via Kafka");
  client.log("  ✅ PDF report generated and uploaded to S3");
  client.log("  ✅ Onboarding saga running");
  client.log("  ✅ GraphQL dashboard query working");
%}
