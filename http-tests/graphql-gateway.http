### [6] Query — Platform Summary (admin only)
POST {{graphqlGatewayUrl}}/graphql
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "query": "query { platformSummary { totalTransactionsToday completedTransactionsToday totalVolumeToday fraudFlagsToday fraudRateToday activeAccounts calculatedAt } }"
}

> {%
  client.test("Platform summary query — 200", function() {
    client.assert(response.status === 200, "Expected 200 OK");
  });
%}

###

### [7] Mutation — Generate Report via GraphQL
POST {{graphqlGatewayUrl}}/graphql
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "query": "mutation GenerateReport($input: GenerateReportInput!) { generateReport(input: $input) { id name status reportType } }",
  "variables": {
    "input": {
      "accountId": "{{accountId}}",
      "reportType": "ANALYTICS_SUMMARY",
      "format": "PDF"
    }
  }
}

> {%
  client.test("Generate report mutation — 200", function() {
    client.assert(response.status === 200, "Expected 200 OK");
  });
  client.test("No GraphQL errors", function() {
    client.assert(response.body.errors === undefined,
      "Expected no errors");
  });
  client.test("Report created", function() {
    client.assert(response.body.data.generateReport.id !== undefined,
      "Expected report id");
  });
%}

###

### [8] Query — GraphQL Introspection (dev only)
POST {{graphqlGatewayUrl}}/graphql
Content-Type: application/json

{
  "query": "{ __schema { queryType { name } types { name kind } } }"
}

> {%
  client.test("Introspection works — 200", function() {
    client.assert(response.status === 200, "Expected 200 OK");
  });
  client.test("Schema has queryType", function() {
    client.assert(
      response.body.data.__schema.queryType !== undefined,
      "Expected queryType");
  });
%}

###

### [9] Query — With Errors (invalid accountId type)
POST {{graphqlGatewayUrl}}/graphql
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "query": "query { account(id: \"\") { id email } }"
}

> {%
  client.test("Empty id returns null or error gracefully", function() {
    client.assert(response.status === 200,
      "GraphQL always returns 200 even for errors");
  });
%}
